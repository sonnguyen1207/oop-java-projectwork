<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" alignment="TOP_CENTER"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="fi.oop.MainController"
      style="-fx-background-color: #f4f6f8;">

    <padding>
        <Insets top="20" right="30" bottom="20" left="30"/>
    </padding>

    <!-- Title -->
    <Label text="📚 School Library"
           style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />

    <!-- Item List -->
    <ListView fx:id="itemListView"
              prefHeight="280"
              prefWidth="700"
              style="-fx-font-size: 16px;" />

    <!-- Item Info -->
    <Label fx:id="itemInfoLabel"
           text="Select an item to see details."
           wrapText="true"
           prefWidth="700"
           style="-fx-font-size: 16px; -fx-background-color: white; -fx-padding: 15; -fx-border-color: lightgray;" />

    <!-- User Combo -->
    <ComboBox fx:id="userComboBox"
              onAction="#handleUserSelection"
              prefWidth="320"
              style="-fx-font-size: 16px;" />

    <!-- User Info -->
    <Label fx:id="userInfoLabel"
           text="Select a user."
           wrapText="true"
           prefWidth="700"
           style="-fx-font-size: 16px; -fx-background-color: white; -fx-padding: 15; -fx-border-color: lightgray;" />

    <!-- Buttons -->
    <HBox spacing="15" alignment="CENTER">
        <Button text="Borrow"
                onAction="#handleBorrow"
                prefWidth="120"
                style="-fx-font-size: 16px; -fx-background-color: #3498db; -fx-text-fill: white;" />

        <Button text="Return"
                onAction="#handleReturn"
                prefWidth="120"
                style="-fx-font-size: 16px; -fx-background-color: #27ae60; -fx-text-fill: white;" />
    </HBox>

    <!-- Status -->
    <Label fx:id="statusLabel"
           text="Ready."
           wrapText="true"
           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #e74c3c;" />

</VBox>